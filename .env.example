# ============================================================
# HanRao Realty — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit your real .env file to version control.
# ============================================================

# ── MongoDB (Required for Admin Panel + Form Submissions) ──
# Get this from MongoDB Atlas → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your-user:your-password@your-cluster.mongodb.net/hanrao?retryWrites=true&w=majority

# ── Admin Credentials ──────────────────────────────────────
# Used on the /admin/login page
ADMIN_EMAIL=admin@hanraorealty.com
ADMIN_PASSWORD=your-secure-password-here

# ============================================================
# Without MONGODB_URI the project runs in DEVELOPMENT MODE:
#   - All public pages load with realistic mock data.
#   - The admin panel shows a configuration notice.
#   - No data is written to any database.
# ============================================================
